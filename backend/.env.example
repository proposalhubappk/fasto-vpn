NODE_ENV=production
PORT=4000
API_PREFIX=/api/v1
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>/<db>?retryWrites=true&w=majority
CORS_ORIGIN=*

JWT_ACCESS_SECRET=replace_with_long_access_secret
JWT_REFRESH_SECRET=replace_with_long_refresh_secret
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d
BCRYPT_SALT_ROUNDS=12

ADMIN_DEFAULT_EMAIL=admin@fastovpn.com
ADMIN_DEFAULT_PASSWORD=replace_with_strong_password

FREE_PROXY_LIMIT=20
PREMIUM_PLAN_PRICE_USD=9.99

REVENUECAT_WEBHOOK_SECRET=replace_with_revenuecat_webhook_secret

FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=
FIREBASE_SKIP_VERIFY=false

GEO_LOOKUP_URL=https://ipwhois.app/json
